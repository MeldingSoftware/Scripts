#!/usr/bin/env bash
set -euo pipefail

TITLE="MeldingSoftware"
INSTALL_DIR="$HOME/.MeldingSoftware"
SCRIPTS_DIR="$INSTALL_DIR/scripts"
BASE_URL="https://raw.githubusercontent.com/MeldingSoftware/Scripts/main/Mac"
ZIP_NAME="MeldingSoftware_Mac_Scripts.zip"
ZIP_URL="$BASE_URL/$ZIP_NAME"

pause() {
  echo ""
  read -r -p "Press Enter to return to the menu..." _ </dev/tty || true
}

run_script() {
  local script="$1"
  local path="$SCRIPTS_DIR/$script"

  if [[ ! -f "$path" ]]; then
    echo ""
    echo "Missing script: $script"
    echo "Expected location: $path"
    echo ""
    echo "Try running option 13 to update/reinstall scripts."
    pause
    return
  fi

  chmod +x "$path" 2>/dev/null || true
  clear
  echo "Running $script"
  echo "------------------------------------------------------------"
  bash "$path"
  pause
}

update_meldingsoftware() {
  clear
  echo "Updating MeldingSoftware..."
  echo ""

  TMP_DIR="$(mktemp -d)"
  ZIP_PATH="$TMP_DIR/$ZIP_NAME"
  EXTRACT_DIR="$TMP_DIR/extract"

  cleanup() {
    rm -rf "$TMP_DIR"
  }
  trap cleanup RETURN

  mkdir -p "$EXTRACT_DIR"

  echo "Downloading latest scripts package..."
  curl -fsSL "$ZIP_URL" -o "$ZIP_PATH"

  echo "Extracting scripts..."
  /usr/bin/unzip -q "$ZIP_PATH" -d "$EXTRACT_DIR"

  SOURCE_DIR=""
  if [[ -f "$EXTRACT_DIR/Melder.sh" ]] || [[ -f "$EXTRACT_DIR/DeBloater.sh" ]]; then
    SOURCE_DIR="$EXTRACT_DIR"
  else
    while IFS= read -r dir; do
      if [[ -f "$dir/Melder.sh" ]] || [[ -f "$dir/DeBloater.sh" ]]; then
        SOURCE_DIR="$dir"
        break
      fi
    done < <(find "$EXTRACT_DIR" -type d)
  fi

  if [[ -z "$SOURCE_DIR" ]]; then
    echo "Could not find scripts inside the ZIP."
    pause
    return
  fi

  rm -rf "$SCRIPTS_DIR"
  mkdir -p "$SCRIPTS_DIR"
  find "$SOURCE_DIR" -maxdepth 1 -type f -name "*.sh" -exec cp "{}" "$SCRIPTS_DIR/" \;
  chmod +x "$SCRIPTS_DIR"/*.sh 2>/dev/null || true

  echo ""
  echo "Update complete."
  pause
}

uninstall_meldingsoftware() {
  clear
  echo "Uninstall MeldingSoftware?"
  echo ""
  echo "This will remove:"
  echo "  $HOME/.MeldingSoftware"
  echo "  $HOME/.local/bin/MeldingSoftware"
  echo ""
  echo "It will not remove Homebrew, installed apps, or other files in ~/.local/bin."
  echo ""
  read -r -p "Type uninstall to continue: " confirm </dev/tty || confirm=""

  if [[ "$confirm" == "uninstall" ]]; then
    rm -rf "$HOME/.MeldingSoftware"
    rm -f "$HOME/.local/bin/MeldingSoftware"

    echo ""
    echo "MeldingSoftware removed."
    echo ""
    echo "Close and reopen Terminal if the command still appears cached."
    echo ""
    exit 0
  else
    echo ""
    echo "Uninstall cancelled."
    pause
  fi
}

while true; do
  clear
  echo "MeldingSoftware"
  echo "------------------------------------------------------------"
  echo "Select a script to run:"
  echo ""
  echo "  0) Exit"
  echo "  1) DeBloater"
  echo "  2) Fun Commands"
  echo "  3) Installed Apps"
  echo "  4) Largest Files"
  echo "  5) Maintenance"
  echo "  6) Melder"
  echo "  7) Print Spooler Fix"
  echo "  8) Recon"
  echo "  9) Repair Tool"
  echo " 10) System Info"
  echo " 11) Update Fix"
  echo " 12) Wi-Fi Info"
  echo " 13) Update MeldingSoftware"
  echo " 14) Uninstall MeldingSoftware"
  echo ""
  read -r -p "Enter a number: " choice </dev/tty || choice=""

  case "$choice" in
    0) clear; exit 0 ;;
    1) run_script "DeBloater.sh" ;;
    2) run_script "Fun_Commands.sh" ;;
    3) run_script "Installed_Apps.sh" ;;
    4) run_script "Largest_Files.sh" ;;
    5) run_script "Maintenance.sh" ;;
    6) run_script "Melder.sh" ;;
    7) run_script "Print_Spooler_Fix.sh" ;;
    8) run_script "Recon.sh" ;;
    9) run_script "Repair_Tool.sh" ;;
    10) run_script "System_Info.sh" ;;
    11) run_script "Update_Fix.sh" ;;
    12) run_script "Wi-Fi_Info.sh" ;;
    13) update_meldingsoftware ;;
    14) uninstall_meldingsoftware ;;
    *) echo "Invalid choice."; sleep 1 ;;
  esac
done
