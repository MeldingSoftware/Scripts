#!/usr/bin/env bash
set -euo pipefail

TITLE="MeldingSoftware"
INSTALL_DIR="$HOME/.MeldingSoftware"
SCRIPTS_DIR="$INSTALL_DIR/scripts"
BASE_URL="https://raw.githubusercontent.com/MeldingSoftware/Scripts/main/Mac"

pause() {
  echo ""
  read -r -p "Press Enter to return to the menu..."
}

run_script() {
  local script="$1"
  local path="$SCRIPTS_DIR/$script"

  if [[ ! -f "$path" ]]; then
    echo ""
    echo "Missing script: $script"
    echo "Expected location: $path"
    echo ""
    echo "Try running option 13 to update/reinstall scripts."
    pause
    return
  fi

  chmod +x "$path" 2>/dev/null || true
  clear
  echo "Running $script"
  echo "------------------------------------------------------------"
  bash "$path"
  pause
}

download_script() {
  local name="$1"
  local url="$BASE_URL/$name"
  local dest="$SCRIPTS_DIR/$name"

  echo "Updating $name..."
  curl -fsSL "$url" -o "$dest"
  chmod +x "$dest"
}

update_meldingsoftware() {
  clear
  echo "Updating MeldingSoftware..."
  echo ""

  mkdir -p "$SCRIPTS_DIR"

  download_script "DeBloater.sh"
  download_script "FunCommands.sh"
  download_script "InstalledApps.sh"
  download_script "LargestFiles.sh"
  download_script "Maintenance.sh"
  download_script "Melder.sh"
  download_script "PrintSpoolerFix.sh"
  download_script "Recon.sh"
  download_script "RepairTool.sh"
  download_script "SystemInfo.sh"
  download_script "UpdateFix.sh"
  download_script "Wi-FiInfo.sh"

  echo ""
  echo "Update complete."
  pause
}

uninstall_meldingsoftware() {
  clear
  echo "Uninstall MeldingSoftware?"
  echo ""
  echo "This will remove:"
  echo "  $HOME/.MeldingSoftware"
  echo "  $HOME/.local/bin/MeldingSoftware"
  echo ""
  echo "It will not remove Homebrew, installed apps, or other files in ~/.local/bin."
  echo ""
  read -r -p "Type uninstall to continue: " confirm

  if [[ "$confirm" == "uninstall" ]]; then
    rm -rf "$HOME/.MeldingSoftware"
    rm -f "$HOME/.local/bin/MeldingSoftware"

    echo ""
    echo "MeldingSoftware removed."
    echo ""
    echo "Note:"
    echo "The PATH entry for ~/.local/bin may remain in your shell profile."
    echo "That is safe to leave because other tools may also use ~/.local/bin."
    echo ""
    echo "Close and reopen Terminal if the command still appears cached."
    echo ""
    exit 0
  else
    echo ""
    echo "Uninstall cancelled."
    pause
  fi
}

while true; do
  clear
  echo "MeldingSoftware"
  echo "------------------------------------------------------------"
  echo "Select a script to run:"
  echo ""
  echo "  0) Exit"
  echo "  1) DeBloater"
  echo "  2) Fun Commands"
  echo "  3) Installed Apps"
  echo "  4) Largest Files"
  echo "  5) Maintenance"
  echo "  6) Melder"
  echo "  7) Print Spooler Fix"
  echo "  8) Recon"
  echo "  9) Repair Tool"
  echo " 10) System Info"
  echo " 11) Update Fix"
  echo " 12) Wi-Fi Info"
  echo " 13) Update MeldingSoftware"
  echo " 14) Uninstall MeldingSoftware"
  echo ""
  read -r -p "Enter a number: " choice

  case "$choice" in
    0) clear; exit 0 ;;
    1) run_script "DeBloater.sh" ;;
    2) run_script "FunCommands.sh" ;;
    3) run_script "InstalledApps.sh" ;;
    4) run_script "LargestFiles.sh" ;;
    5) run_script "Maintenance.sh" ;;
    6) run_script "Melder.sh" ;;
    7) run_script "PrintSpoolerFix.sh" ;;
    8) run_script "Recon.sh" ;;
    9) run_script "RepairTool.sh" ;;
    10) run_script "SystemInfo.sh" ;;
    11) run_script "UpdateFix.sh" ;;
    12) run_script "Wi-FiInfo.sh" ;;
    13) update_meldingsoftware ;;
    14) uninstall_meldingsoftware ;;
    *) echo "Invalid choice."; sleep 1 ;;
  esac
done
